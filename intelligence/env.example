# ============================================================
#  PocketLedger SA — Intelligence Service Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to GitHub — it's in .gitignore already.
# ============================================================

# SQL Server (AWS RDS)
DB_SERVER=your-rds-instance.amazonaws.com
DB_PORT=1433
DB_NAME=Pocket_Ledger_SA
DB_USER=admin
DB_PASSWORD=your_password_here

# AWS credentials (use IAM role in production, keys only for local dev)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=af-south-1

# S3 bucket for receipt images
S3_BUCKET_NAME=pocketledger-receipts

# AWS Cognito (for validating user JWTs from the mobile app)
COGNITO_USER_POOL_ID=af-south-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=af-south-1

# API config
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
